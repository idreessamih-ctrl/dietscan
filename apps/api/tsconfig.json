{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@openfoodfacts/openfoodfacts-nodejs": ["node_modules/@openfoodfacts/openfoodfacts-nodejs/dist/types/src/index.d.ts"],
      "meilisearch": ["node_modules/meilisearch/dist/types/index.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
