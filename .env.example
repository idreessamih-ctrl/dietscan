# ==============================================================================
# DietScan Environment Configuration Template
# Copy this file to .env and replace the placeholder values with actual secrets.
# Do NOT check the .env file with real secrets into source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database Configurations
# ------------------------------------------------------------------------------
# PostgreSQL superuser password
POSTGRES_PASSWORD=your_postgres_password_here

# ------------------------------------------------------------------------------
# Activepieces Configurations
# ------------------------------------------------------------------------------
# 32-character hexadecimal key (e.g., generate with `openssl rand -hex 16`)
AP_ENCRYPTION_KEY=your_ap_encryption_key_32_chars_hex_here
# Secret key for signing JWT tokens in Activepieces
AP_JWT_SECRET=your_ap_jwt_secret_here

# ------------------------------------------------------------------------------
# GlitchTip Configurations
# ------------------------------------------------------------------------------
# Secret key used for cryptographic signing in GlitchTip (Django)
GLITCHTIP_SECRET_KEY=your_glitchtip_secret_key_here

# ------------------------------------------------------------------------------
# Umami Configurations
# ------------------------------------------------------------------------------
# Cryptographic salt/secret used by Umami analytics
UMAMI_APP_SECRET=your_umami_app_secret_here

# ------------------------------------------------------------------------------
# Traefik & Domain Routing Configurations
# ------------------------------------------------------------------------------
# Fully Qualified Domain Names (FQDN) for the services
API_HOST=api.dietscan.example.com
MEILISEARCH_HOST=search.dietscan.example.com
SUPERTOKENS_HOST=auth.dietscan.example.com
GLITCHTIP_HOST=errors.dietscan.example.com
ACTIVEPIECES_HOST=flow.dietscan.example.com
UMAMI_HOST=analytics.dietscan.example.com
